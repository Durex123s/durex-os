# Copie ce fichier en "keystore.properties" (à la racine du projet, à côté
# de settings.gradle) et remplis les vraies valeurs. Ce fichier gabarit est
# suivi par git ; keystore.properties lui-même NE DOIT JAMAIS être commité
# (il est déjà dans .gitignore).
storeFile=veyrion-release.keystore
storePassword=CHANGE_ME
keyAlias=veyrion
keyPassword=CHANGE_ME
